{
  "name": "AlTrapone Bot (Dev)",
  "dockerComposeFile": "../docker/docker-compose.dev.yml",
  "service": "altrapone",
  "workspaceFolder": "/app",
  "remoteUser": "dev",
  "containerUser": "dev",
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/home/dev/.ssh,type=bind,readonly"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  }
}