name: altrapone

services:
  altrapone:
    image: ${ALTRAPONE_IMAGE:?ALTRAPONE_IMAGE is required}
    container_name: altrapone
    restart: unless-stopped
    init: true
    env_file:
      - .env
    read_only: true
    tmpfs:
      - /tmp:size=64m,mode=1777
    volumes:
      - altrapone_data:/app/data
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    stop_grace_period: 20s

volumes:
  altrapone_data:
    name: altrapone_data
